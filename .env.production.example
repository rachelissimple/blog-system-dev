# 生产环境配置
# 复制此文件为 .env.production 并填写实际值

# PostgreSQL数据库连接（Vercel Postgres、Supabase、Neon等）
DATABASE_URL="postgresql://用户名:密码@主机地址:5432/数据库名"

# JWT认证密钥（生成强随机字符串，如：openssl rand -base64 32）
JWT_SECRET="your-strong-jwt-secret-key-change-this-in-production"

# 管理员邮箱列表，用逗号分隔
ADMIN_EMAILS="2161604566@qq.com"

# 可选：应用URL（用于CORS等配置）
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# 可选：是否启用调试模式
NODE_ENV="production"

# 可选：Prisma调试
# PRISMA_CLIENT_ENGINE_TYPE="dataproxy"  # 对于Vercel Data Proxy